# =============================================================================
# Easypanel — serviço do PAINEL admin (ex.: painel), build Vite
#
# VITE_* é gravado no JavaScript no momento do "npm run build:admin".
# Defina no PASSO DE BUILD do Easypanel, não no contentor da API.
#
# Diagnóstico: no login do painel aparece "API: …" — deve ser https://app.chattypebot.com
# Override de emergência no HTML: window.__TYPEBOT_SAAS_API_BASE__ = "https://app.chattypebot.com";
# =============================================================================

VITE_API_BASE_URL=https://app.chattypebot.com

VITE_WIDGET_BASE_URL=https://widget.chattypebot.com
