# =============================================================================
# Easypanel — serviço do PAINEL admin (ex.: painel-typebot-crm), build Vite
#
# VITE_* é gravado no JavaScript no momento do "npm run build:admin".
# Por isso tem de existir como env no PASSO DE BUILD (Dockerfile build-stage /
# Build Command env no Easypanel), não no contentor da API api-typebot-crm.
#
# Se estas variáveis estiverem só na API ou só depois do build, o bundle pode ficar
# com fallback http://localhost:3333 e login/reset falham ou apontam para o sitio errado.
#
# Ajusta URLs aos teus domínios reais (HTTPS, sem barra no fim).
# =============================================================================

VITE_API_BASE_URL=https://SUBSTITUIR_HOST_PUBLICO_DA_API

# Opcional: links de pré-visualização / widget no admin (ver apps/admin/.env.example).
VITE_WIDGET_BASE_URL=https://SUBSTITUIR_HOST_PUBLICO_DO_WIDGET
