# Deploy Git no Easypanel: o título do deploy segue o último commit.
# Para não repetir o mesmo nome sem código novo, ver:
#   doc/EASYPANEL-deploy-mensagens-unicas.md
#   npm run easypanel:deploy-empty -- "api: descrição do que sobe"
#
# =============================================================================
# Easypanel — serviço da API Node (`api`, domínio app.chattypebot.com)
#
# Aqui NÃO entram variáveis VITE_* : essas são só para o build do frontend Vite
# (painel admin). Na API em runtime o Node não lê VITE_API_BASE_URL.
#
# Para o painel: ver doc/EASYPANEL-PAINEL-VITE-build.env.example e aplicar essas
# variáveis no passo de BUILD do serviço do admin (painel-typebot-crm), não aqui.
#
# Copiar para Easypanel → este serviço → Ambiente (uma linha por variável).
# 1) Troca todos SUBSTITUIR_* pelos teus URLs reais (HTTPS, sem espaços).
# 2) Troca SEGREDO_* por valores fortes (não uses os exemplos em produção).
# 3) Porta interna do proxy deve ser a mesma que PORT abaixo (3333).
# =============================================================================

NODE_ENV=production
PORT=3333
HOST=0.0.0.0

# URL pública desta API (a mesma que abres no browser para /health), sem barra no fim.
HANDOFF_PUBLIC_BASE_URL=https://SUBSTITUIR_HOST_PUBLICO_DA_API
TYPEBOT_HANDOFF_WEBHOOK_URL=https://SUBSTITUIR_HOST_PUBLICO_DA_API/api/typebot/handoff

# Onde o utilizador abre o painel admin em produção (links em e-mails / redirects internos).
SYSTEM_LOGIN_URL=https://SUBSTITUIR_HOST_PUBLICO_DO_ADMIN

# Onde o widget público vai ficar quando tiveres esse deploy.
WIDGET_BASE_URL=https://SUBSTITUIR_HOST_PUBLICO_DO_WIDGET

# ---------------------------------------------------------------------------
# JWT (se no futuro usares tokens no backend; mantém forte em produção)
# ---------------------------------------------------------------------------
JWT_SECRET=SEGREDO_ALEATORIO_LONGO_MINIMO_32_CARACTERES

# ---------------------------------------------------------------------------
# Login / assinantes (RECOMENDADO em produção SaaS): Postgres
# ---------------------------------------------------------------------------
# Com DATABASE_URL definido, tenants e atendentes (login) passam a gravar-se em Postgres
# (tabelas saas_tenants, saas_attendants). O disco do contentor da API pode ser recriado
# em cada deploy — os utilizadores continuam na base de dados.
#
# No Easypanel: cria um serviço Postgres, copia a URL interna (ex.: postgres://user:pass@postgres:5432/db)
# para DATABASE_URL neste serviço da API. Na primeira subida a API cria as tabelas automaticamente.
# Se já tiveres JSON em volume e o Postgres estiver vazio, a API copia tenants/attendants dos ficheiros
# para o Postgres uma vez (migração automática).
#
# DATABASE_URL=postgresql://USER:PASS@HOST:5432/typebot_saas
# DATABASE_POOL_MAX=10
#
# Política opcional (produção):
# AUTH_REQUIRE_DATABASE_URL_IN_PRODUCTION=true  → aborta o arranque se não houver DATABASE_URL
# AUTH_ALLOW_JSON_IN_PRODUCTION=true            → permite JSON em disco em produção (ex.: com volume)

# ---------------------------------------------------------------------------
# Persistência em disco (fluxos, fila, bibliotecas, etc.) + fallback login sem Postgres
# ---------------------------------------------------------------------------
# Sem DATABASE_URL, login/assinantes usam `apps/api/data/tenants.json` e `attendants.json`.
# Sem volume em `apps/api/data`, redeploy pode apagar utilizadores → 401.
# Monta volume nesse caminho ou usa Postgres acima.
#
# ⚠ Fluxos/fila continuam sempre em JSON: monta um volume persistente na pasta 
# operationalDataDirectory de GET /health (ver doc/EASYPANEL-VOLUME-FLUXOS-FILA.md).
#
# Recuperação (opcional) se a base JSON estiver vazia ao arranque:
# API_SEED_ON_EMPTY=true
# API_SEED_OWNER_EMAIL=teu@email.com
# API_SEED_OWNER_PASSWORD=senha_inicial_min_4_chars
# API_SEED_TENANT_NAME=Nome do assinante
# API_SEED_WHATSAPP=5511999999999
#
# Master do Sistema (walkup@walkuptec.com.br) — recuperação após Postgres sem este cadastro:
# API_ENSURE_SYSTEM_MASTER=true
# Logo do assinante matriz (walkup@walkuptec.com.br) — apps/api/assets/logo-walkup.png no build
# API_SYSTEM_MASTER_FORCE_LOGO=true   # redeploy uma vez para sobrescrever logo antiga
# API_SYSTEM_MASTER_SKIP_LOGO_BOOT=true
# API_SYSTEM_MASTER_PASSWORD=senha_inicial_min_4_chars
# API_SYSTEM_MASTER_TENANT_NAME=Drax Sistemas
# API_SYSTEM_MASTER_WHATSAPP=5511999999999
# API_SYSTEM_MASTER_RESET_PASSWORD=true
# API_ALLOW_SYSTEM_MASTER_RESET_PROVISION=true

# ---------------------------------------------------------------------------
# Opcional: Redis / MinIO (não ligados ao login Postgres acima)
# ---------------------------------------------------------------------------
# REDIS_URL=redis://HOST:6379
# S3_ENDPOINT=
# S3_PORT=9000
# S3_USE_SSL=true
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=typebot

# ---------------------------------------------------------------------------
# E-mail (copiar os mesmos valores que já te funcionam localmente, se usas reset/boas-vindas)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_MODE=smtp

# ---------------------------------------------------------------------------
# Asaas (página de vendas / checkout público)
# ---------------------------------------------------------------------------
# ASAAS_API_BASE_URL=https://api.asaas.com/v3
# ASAAS_API_BASE_URL=https://api-sandbox.asaas.com/v3
# ASAAS_API_KEY=
# ASAAS_WEBHOOK_ACCESS_TOKEN=
# SALES_PLAN_MONTHLY_VALUE=290.00
# SALES_PLAN_YEARLY_VALUE=2280.00
# SYSTEM_LOGIN_URL=https://painel.chattypebot.com
# Checkout Asaas (assinatura recorrente — Pix ou cartão escolhido no modal da LP)
# SALES_LANDING_URL=https://SUBSTITUIR_URL_DA_PAGINA_DE_VENDAS
# SALES_CHECKOUT_SUCCESS_URL=https://painel.chattypebot.com
# SALES_CHECKOUT_CANCEL_URL=https://SUBSTITUIR_URL_DA_PAGINA_DE_VENDAS
# SALES_CHECKOUT_EXPIRED_URL=https://SUBSTITUIR_URL_DA_PAGINA_DE_VENDAS
# Webhook Asaas: POST https://SUBSTITUIR_HOST_PUBLICO_DA_API/api/webhooks/asaas
# Inclua eventos de Pix Automático (autorização + pagamentos) no painel Asaas.
#
# Pix Automático (assinatura mensal na landing):
# BILLING_PIX_AUTOMATIC_PAYMENT_MODE=SUBSCRIPTION
# SUBSCRIPTION = Asaas gera renovações; MANUAL = API cria cobranças (job BILLING_PIX_RENEWAL_INTERVAL_MS).
# ASAAS_PIX_AUTOMATIC_AUTH_PATH=/pix/automatic/authorizations

# ---------------------------------------------------------------------------
# Typebot Builder / Viewer (Easypanel projeto "typebot" — ver doc/TYPEBOT-ACESSO-E-502-HOJE.md)
# ---------------------------------------------------------------------------
TYPEBOT_BUILDER_API_BASE_URL=https://typebot-typebot-walkup-builder.achpyp.easypanel.host/api
TYPEBOT_BUILDER_API_TOKEN=SEGREDO_TOKEN_BUILDER_API

TYPEBOT_AUTO_CREATE_WORKSPACE=true
TYPEBOT_DEFAULT_IMPORTS_MAP=[]

TYPEBOT_SOURCE_MASTER_WORKSPACE_ID=
TYPEBOT_SOURCE_VIEWER_BASE_URL=https://typebot-typebot-walkup-viewer.achpyp.easypanel.host
TYPEBOT_TARGET_VIEWER_BASE_URL=https://typebot-typebot-walkup-viewer.achpyp.easypanel.host

TYPEBOT_AUTO_SYNC_ACTIVE_MASTER_FLOWS=true
TYPEBOT_AUTO_SYNC_INTERVAL_MS=20000
TYPEBOT_TYPEBOT_IMPORT_ONLY_ACTIVE=true
TYPEBOT_MASTER_FLOWS_WEBHOOK_SECRET=

# Opcional cross-env / cloud (igual ao teu .env local se usas)
TYPEBOT_SOURCE_BUILDER_API_BASE_URL=
TYPEBOT_SOURCE_BUILDER_API_TOKEN=
TYPEBOT_TARGET_BUILDER_API_BASE_URL=
TYPEBOT_TARGET_BUILDER_API_TOKEN=
TYPEBOT_TARGET_PUBLIC_BASE_URL=

TYPEBOT_TENANT_URL_TEMPLATE=
TYPEBOT_DEFAULT_DASHBOARD_URL=https://typebot-typebot-walkup-builder.achpyp.easypanel.host/pt-BR/typebots
TYPEBOT_SYSTEM_MASTER_URL=https://typebot-typebot-walkup-builder.achpyp.easypanel.host/pt-BR/typebots
TYPEBOT_AUTH_MODE=manual
# API pública para logo/share-image (data:image no cadastro → URL https no Typebot)
TYPEBOT_AVATAR_PUBLIC_BASE_URL=https://app.chattypebot.com
# Reescreve URLs MinIO localhost nos fluxos (opcional na API)
TYPEBOT_S3_PUBLIC_BASE_URL=https://typebot-minio.achpyp.easypanel.host/typebot/public

# Importação extra (só se usares)
TYPEBOT_IMPORT_FULL_SOURCE_WORKSPACE=false

# ---------------------------------------------------------------------------
# SSO (só preencher quando integrares)
# ---------------------------------------------------------------------------
TYPEBOT_SSO_PROVIDER=
TYPEBOT_SSO_ISSUER_URL=
TYPEBOT_SSO_CLIENT_ID=
TYPEBOT_SSO_AUDIENCE=
TYPEBOT_SSO_REALM=
TYPEBOT_SSO_CALLBACK_URL=
TYPEBOT_SSO_LOGOUT_URL=
