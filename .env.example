NODE_ENV=development
PORT=3333
WIDGET_BASE_URL=http://localhost:5174

# Base pública da API em links do handoff (Redirect). Use quando o Typebot chama via túnel/ngrok
# e o Host da requisição não é o domínio que o utilizador deve abrir (evita URL com localhost).
# Ex.: HANDOFF_PUBLIC_BASE_URL=https://api.seudominio.com
HANDOFF_PUBLIC_BASE_URL=

# Asaas (checkout da página de vendas)
# Sandbox: https://api-sandbox.asaas.com/v3
ASAAS_API_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_ACCESS_TOKEN=
SALES_PLAN_MONTHLY_VALUE=197.00
SALES_PLAN_YEARLY_VALUE=1970.00

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/typebot_saas
REDIS_URL=redis://localhost:6379

S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=typebot

JWT_SECRET=change-me

# Typebot direct access (optional)
# If TYPEBOT_TENANT_URL_TEMPLATE is set, activation marks tenant as provisioned and
# stores a direct access URL per tenant, replacing placeholders:
# - {tenantSlug}  (tenant name slugified)
# - {tenantId}
# - {ownerEmail} (url-encoded)
# Example:
# TYPEBOT_TENANT_URL_TEMPLATE=https://{tenantSlug}-typebot-walkup-builder.achypp.easypanel.host/pt-BR/typebots
TYPEBOT_TENANT_URL_TEMPLATE=

# Fallback dashboard URL when no tenant URL template is configured.
# Preferir URL do builder self-host (evita abrir cloud app.typebot.com por engano).
TYPEBOT_DEFAULT_DASHBOARD_URL=

# Optional fixed URL for system master tenant
TYPEBOT_SYSTEM_MASTER_URL=

# Typebot auth capability (manual | magic_link | sso)
# manual     -> sempre exige login no dominio do Typebot
# magic_link -> pode exigir validacao por e-mail no primeiro acesso
# sso        -> acesso pode ser direto via federacao (quando configurado no provedor)
TYPEBOT_AUTH_MODE=manual

# Typebot Builder API (provisionamento real de workspace + import automático)
# Exemplo de mapa:
# TYPEBOT_DEFAULT_IMPORTS_MAP=[{"matchViewerUrl":"https://soma-typebot-walkup-viewer.achpyp.easypanel.host/emprestimo-clt","sourceTypebotId":"<TYPEBOT_ID_CLT>","name":"CLT"}]
TYPEBOT_BUILDER_API_BASE_URL=
TYPEBOT_BUILDER_API_TOKEN=
TYPEBOT_AUTO_CREATE_WORKSPACE=true
TYPEBOT_DEFAULT_IMPORTS_MAP=[]

# Opcional: import cross-environment (matriz self-host -> workspace cloud do assinante)
# - Leitura do schema: TYPEBOT_SOURCE_* (default = TYPEBOT_BUILDER_*)
# - Criar workspace / listar / importar: TYPEBOT_TARGET_* (default = TYPEBOT_BUILDER_*)
# - Se o host de destino for diferente da fonte, TYPEBOT_TARGET_BUILDER_API_TOKEN e obrigatorio (token cloud).
# - Lista todos os typebots do workspace matriz e importa no destino (idempotente por nome):
TYPEBOT_SOURCE_MASTER_WORKSPACE_ID=
# Base do viewer público da matriz (sem slug do bot). Obrigatório se TYPEBOT_SOURCE_MASTER_WORKSPACE_ID
# estiver definido e TYPEBOT_TYPEBOT_IMPORT_ONLY_ACTIVE=true (padrão).
TYPEBOT_SOURCE_VIEWER_BASE_URL=
# Opcional: base do viewer dos bots importados no workspace do assinante (default = TYPEBOT_SOURCE_VIEWER_BASE_URL).
# Usado para gravar em SavedFlow.url o link público correto (ex. .../clt-xop5yt8) após sync / ao copiar link.
TYPEBOT_TARGET_VIEWER_BASE_URL=
# Auto-sync dos fluxos ativos da matriz para todos os assinantes (startup + intervalo).
TYPEBOT_AUTO_SYNC_ACTIVE_MASTER_FLOWS=true
TYPEBOT_AUTO_SYNC_INTERVAL_MS=20000
# Webhook (opcional) para Typebot notificar fluxo ativo novo na matriz.
# Endpoint: POST /api/typebot/webhooks/master-active-flows
# Header: x-webhook-secret: <valor abaixo>
TYPEBOT_MASTER_FLOWS_WEBHOOK_SECRET=
# true (default): só importa fluxos com URL pública respondendo HTTP 2xx (padrão biblioteca + matriz).
TYPEBOT_TYPEBOT_IMPORT_ONLY_ACTIVE=true
TYPEBOT_TARGET_BUILDER_API_BASE_URL=
TYPEBOT_TARGET_BUILDER_API_TOKEN=
TYPEBOT_TARGET_PUBLIC_BASE_URL=

# -------------------------------------------------------------------
# SSO readiness (preencher quando for integrar de fato com SSO)
# -------------------------------------------------------------------
# Provedor de identidade (ex.: auth0, azuread, keycloak, okta)
TYPEBOT_SSO_PROVIDER=

# URL do issuer OIDC/SAML (ex.: https://tenant.auth0.com/)
TYPEBOT_SSO_ISSUER_URL=

# Client ID / Audience / Realm conforme o provedor
TYPEBOT_SSO_CLIENT_ID=
TYPEBOT_SSO_AUDIENCE=
TYPEBOT_SSO_REALM=

# URL de callback/ACS registrada no provedor e no Typebot
TYPEBOT_SSO_CALLBACK_URL=

# URL de logout federado (opcional)
TYPEBOT_SSO_LOGOUT_URL=
