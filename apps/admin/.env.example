# Build-time (Vite / npm run build:admin). NÃO vai para o contentor da API Node.
# No Easypanel: variáveis VITE_* no serviço do PAINEL, no ambiente do BUILD — ver doc/EASYPANEL-PAINEL-VITE-build.env.example
VITE_API_BASE_URL=https://api.chattypebot.com

# URL pública do widget (links “ver como atendente”, pré-visualização).
VITE_WIDGET_BASE_URL=https://widget.chattypebot.com

# URL pública do Builder Typebot (botão "Acessar Typebot" no painel Master do Sistema).
# Defina sem prefixo "soma-" se essa for a sua regra de marca/domínio.
VITE_SYSTEM_MASTER_TYPEBOT_BUILDER_URL=https://typebot-walkup-builder.achpyp.easypanel.host/pt-BR/typebots
